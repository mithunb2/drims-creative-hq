# Copy this file to .env and fill in real values, OR run
# `bash skills/install-skill.sh` which writes ~/.drims-classify.env for you.
#
# The dashboard (browser side) does NOT read from .env — it reads from config.js.
# .env is only for local tooling and the classify-inspiration skill.

# Supabase — from Settings → API in the Supabase dashboard
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_HOST=xxxxxxxxxxxxxxxx.supabase.co
# Service role key bypasses RLS. Only used locally by the skill. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ClickUp
CLICKUP_API_KEY=pk_XXXXXXXXXXXXXXXX
CLICKUP_WORKSPACE_ID=
CLICKUP_INSPIRATION_FOLDER_ID=
CLICKUP_SPACE_ID=
